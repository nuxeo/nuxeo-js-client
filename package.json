{
  "name": "nuxeo",
  "description": "JavaScript client library for Nuxeo API",
  "version": "5.0.0",
  "main": "./lib/index.js",
  "author": "Nuxeo (http://www.nuxeo.com/)",
  "contributors": [
    {
      "name": "Thomas Roger",
      "email": "troger@nuxeo.com"
    }
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/nuxeo/nuxeo-js-client",
  "repository": {
    "type": "git",
    "url": "git://github.com/nuxeo/nuxeo-js-client.git"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "nuxeo"
  ],
  "dependencies": {
    "buffer": "^6.0.0",
    "extend": "^3.0.0",
    "md5": "^2.0.0",
    "promise-queue": "^2.0.0",
    "qs": "^6.15.1",
    "random-js": "^2.1.0"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^8.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.0.0",
    "express": "^4.0.0",
    "fs-extra": "^11.0.0",
    "jsdoc": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.3",
    "vite-plugin-commonjs": "^0.10.4",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "clean": "rimraf ${JS_DIST_DIR:-dist} ${JS_BUILD_DIR:-build}",
    "build": "npm run clean && npm run build:dist && npm run build:browser",
    "build:dist": "node bin/build-dist.js",
    "build:browser": "mkdirp ${JS_DIST_DIR:-dist} && esbuild lib/index-browserify.js --bundle --format=iife --platform=browser --external:crypto --outfile=${JS_DIST_DIR:-dist}/nuxeo.js",
    "lint": "eslint 'lib' 'test'",
    "pretest": "rimraf coverage && npm run lint",
    "test": "npm run test:cover && npm run test:browser",
    "test:cover": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:node": "vitest run",
    "test:browser": "vitest run --config vitest.config.browser.mjs",
    "it": "npm run it:checkstyle && npm run build && npm run it:cover && npm run it:browser",
    "it:checkstyle": "eslint 'lib' 'test' --format checkstyle --output-file ftest/target/checkstyle-result.xml",
    "it:cover": "vitest run --coverage --coverage.reporter=cobertura --coverage.reportsDirectory=$JS_REPORTS_DIR --reporter=junit --outputFile=ftest/target/$JS_REPORTS_DIR/test-results-node.xml",
    "it:node": "vitest run --reporter=junit --outputFile=ftest/target/$JS_REPORTS_DIR/test-results-node.xml",
    "it:browser": "vitest run --config vitest.config.browser.mjs --reporter=junit --outputFile=ftest/target/$JS_REPORTS_DIR/test-results-browser.xml",
    "doc": "jsdoc -c jsdoc.json",
    "start": "npm run build:browser && node examples/server.js"
  },
  "browser": {
    "promise-queue": "promise-queue/lib/index.js",
    "./lib/deps/fetch.js": "./lib/deps/fetch-browser.js",
    "./lib/deps/utils/buffer.js": "./lib/deps/utils/buffer-browser.js"
  },
  "react-native": {
    "./lib/deps/fetch.js": "./lib/deps/fetch-react-native.js"
  }
}

{
  "name": "nuxeo",
  "description": "JavaScript client library for Nuxeo API",
  "version": "5.0.0",
  "main": "./lib/index.js",
  "author": "Nuxeo (http://www.nuxeo.com/)",
  "contributors": [
    {
      "name": "Thomas Roger",
      "email": "troger@nuxeo.com"
    }
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/nuxeo/nuxeo-js-client",
  "repository": {
    "type": "git",
    "url": "git://github.com/nuxeo/nuxeo-js-client.git"
  },
  "engines": {
    "node": ">= 18"
  },
  "keywords": [
    "nuxeo"
  ],
  "dependencies": {
    "buffer": "^6.0.0",
    "es6-promise": "^4.0.0",
    "extend": "^3.0.0",
    "form-data": "^4.0.0",
    "md5": "^2.0.0",
    "mocha": "^10.0.0",
    "node-fetch": "^2.0.0",
    "promise-queue": "^2.0.0",
    "querystring": "^0.2.0",
    "random-js": "^1.0.0",
    "whatwg-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.0.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/sauce-service": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/static-server-service": "^9.0.0",
    "babelify": "^10.0.0",
    "browserify": "^17.0.0",
    "chai": "^4.0.0",
    "content-disposition": "^0.5.0",
    "dirty-chai": "^2.0.0",
    "eslint": "^9.26.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.0.0",
    "express": "^4.0.0",
    "fs-extra": "^11.0.0",
    "jsdoc": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "junit-report-builder": "^5.1.1",
    "mkdirp": "^2.0.0",
    "mocha-jenkins-reporter": "^0.4.0",
    "nyc": "^15.0.0",
    "rimraf": "^4.0.0"
  },
  "scripts": {
    "clean": "rimraf ${JS_DIST_DIR:-dist} ${JS_BUILD_DIR:-build}",
    "build": "npm run clean && npm run build:dist && npm run build:browser",
    "build:dist": "node bin/build-dist.js",
    "build:browser": "mkdirp ${JS_DIST_DIR:-dist} && browserify --entry lib/index-browserify.js --transform babelify --outfile ${JS_DIST_DIR:-dist}/nuxeo.js",
    "build:tests": "mkdirp ${JS_BUILD_DIR:-build} && browserify test/helpers/setup.js test/helpers/setup-browser.js test/helpers/setup-logging.js $(find test -name '*.spec.js') --transform babelify --outfile ${JS_BUILD_DIR:-build}/tests.js",
    "lint": "eslint 'lib' 'test'",
    "pretest": "rimraf coverage && npm run lint",
    "test": "npm run test:cover && npm run test:browser",
    "test:cover": "nyc --include lib --all --reporter text --reporter lcov npm run test:node",
    "test:node": "mocha --timeout 30000 --require test/helpers/setup.js --require test/helpers/setup-node.js 'test/helpers/setup-logging.js' 'test/**/*.spec.js'",
    "test:browser": "npm run build:browser && npm run build:tests && npx wdio run ./wdio.conf.js",
    "it": "npm run it:checkstyle && npm run build && npm run it:cover && npm run it:browser",
    "it:checkstyle": "eslint 'lib' 'test' --format checkstyle --output-file ftest/target/checkstyle-result.xml",
    "it:cover": "nyc --temp-dir $JS_REPORTS_DIR/.nyc_output --include lib --all --reporter cobertura --report-dir=$JS_REPORTS_DIR npm run it:node",
    "it:node": "mocha --timeout 30000 --require test/helpers/setup.js --require test/helpers/setup-node.js 'test/helpers/setup-logging.js' --reporter mocha-jenkins-reporter --reporter-options junit_report_path=ftest/target/$JS_REPORTS_DIR/test-results-node.xml,junit_report_stack=1,junit_report_name=node 'test/**/*.spec.js'",
    "it:browser": "npm run build:tests && npx wdio run ./wdio.conf.js",
    "doc": "jsdoc -c jsdoc.json",
    "start": "npm run build:browser && node examples/server.js"
  },
  "browser": {
    "promise-queue": "promise-queue/lib/index.js",
    "./lib/deps/fetch.js": "./lib/deps/fetch-browser.js",
    "./lib/deps/promise.js": "./lib/deps/promise-browser.js",
    "./lib/deps/form-data.js": "./lib/deps/form-data-browser.js",
    "./lib/deps/utils/buffer.js": "./lib/deps/utils/buffer-browser.js"
  },
  "react-native": {
    "./lib/deps/fetch.js": "./lib/deps/fetch-react-native.js",
    "./lib/deps/promise.js": "./lib/deps/promise.js"
  }
}
